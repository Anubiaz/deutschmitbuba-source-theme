{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}

{{> "reading-progress"}}

<main id="gh-main" class="gh-main buba-article-main">

    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">

            {{#if primary_tag}}
                <a class="gh-article-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            <h1 class="gh-article-title is-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="gh-article-excerpt is-body">{{custom_excerpt}}</p>
            {{/if}}

            {{#if @custom.show_post_metadata}}
                <div class="gh-meta-share">
                    <div class="gh-article-meta">
                        <div class="gh-article-author-image instapaper_ignore">
                            {{#foreach authors}}
                                {{#if profile_image}}
                                    <a href="{{url}}">
                                        <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                                    </a>
                                {{else}}
                                    <a href="{{url}}">{{> "icons/avatar"}}</a>
                                {{/if}}
                            {{/foreach}}
                        </div>
                        <div class="gh-article-meta-wrapper">
                            <h4 class="gh-article-author-name">{{authors}}</h4>
                            <div class="gh-article-meta-content">
                                <time class="gh-article-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                                {{#if reading_time}}
                                    <span class="gh-article-meta-length"><span class="bull">—</span> {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                    <a href="#/share" class="gh-button gh-button-share">
                        {{t "Share"}}
                    </a>
                </div>
            {{/if}}

            {{> "feature-image"}}

        </header>

        <aside class="buba-lesson-intro gh-canvas" aria-label="Lernziel dieser Lektion">
            <div>
                <span class="buba-lesson-label">Lernziel</span>
                <p>
                    {{#if custom_excerpt}}
                        {{custom_excerpt}}
                    {{else}}
                        Lies zuerst die Erklärung, merke dir die Beispiele und probiere danach eigene Sätze für deinen Alltag.
                    {{/if}}
                </p>
            </div>
            <div class="buba-lesson-badges" aria-label="Einordnung">
                {{#if primary_tag}}
                    <a href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                {{/if}}
                <span>Deutsch im Alltag</span>
            </div>
        </aside>

        <section class="gh-content gh-canvas is-body{{#if @custom.enable_drop_caps_on_posts}} drop-cap{{/if}}">
            {{content}}
        </section>

        {{#unless @member}}
            <aside class="buba-ad-slot buba-ad-slot-article gh-canvas" aria-label="Werbeplatz">
                <span>Anzeige</span>
            </aside>
        {{/unless}}

        {{#unless @member.paid}}
            {{#if @site.members_enabled}}
                <aside class="buba-member-box buba-article-member-cta gh-canvas">
                    <strong>Mehr mit Buba üben</strong>
                    <p>Mitglieder bekommen Übungen mit Lösungen, Merkblätter, Wortlisten und Downloads ohne Werbung.</p>
                    <a class="buba-button buba-button-primary" href="#/portal/signup" data-portal="signup">Mitglied werden <span aria-hidden="true">→</span></a>
                </aside>
            {{/if}}
        {{/unless}}

        {{#primary_author}}
            <aside class="buba-author-box gh-canvas">
                {{#if profile_image}}
                    <img src="{{img_url profile_image size="xs"}}" alt="{{name}}" width="80" height="80" loading="lazy">
                {{/if}}
                <div>
                    <span>Autor</span>
                    <strong>{{name}}</strong>
                    {{#if bio}}<p>{{bio}}</p>{{/if}}
                    <a href="{{url}}">Weitere Beiträge ansehen <span aria-hidden="true">→</span></a>
                </div>
            </aside>
        {{/primary_author}}

        <footer class="buba-article-paths" aria-label="Weiterlernen">
            <div>
                <strong>Weiterlernen nach Thema</strong>
                <span>Finde direkt die nächste passende Lektion.</span>
            </div>
            <nav aria-label="Themen">
                {{#if primary_tag}}
                    <a href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                {{/if}}
                {{#match primary_tag.slug "!=" "grammatik"}}
                    <a href="/tag/grammatik/">Grammatik</a>
                {{/match}}
                {{#match primary_tag.slug "!=" "wortschatz"}}
                    <a href="/tag/wortschatz/">Wortschatz</a>
                {{/match}}
                {{#match primary_tag.slug "!=" "alltag"}}
                    <a href="/tag/alltag/">Alltag</a>
                {{/match}}
                {{#if @member}}
                    <a href="/mitglieder/">Lernbereich</a>
                {{/if}}
            </nav>
        </footer>

    </article>

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments}}
        </div>
    {{/if}}

</main>

{{/post}}

{{#if @custom.show_related_articles}}
    {{#if post.tags}}
        {{#if @member.paid}}
            {{#get "posts" include="authors,tags" filter="tags:[{{post.tags}}]+id:-{{post.id}}" limit="4" as |next|}}
                {{#if next}}
                    <section class="gh-container is-grid gh-outer">
                        <div class="gh-container-inner gh-inner">
                            <h2 class="gh-container-title">{{t "Read more"}}</h2>
                            <div class="gh-feed">
                                {{#foreach next}}
                                    {{> "post-card" lazyLoad=true}}
                                {{/foreach}}
                            </div>
                        </div>
                    </section>
                {{else}}
                    {{#get "posts" include="authors,tags" filter="id:-{{../post.id}}" limit="4" as |fallback|}}
                        {{#if fallback}}
                            <section class="gh-container is-grid gh-outer">
                                <div class="gh-container-inner gh-inner">
                                    <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                    <div class="gh-feed">
                                        {{#foreach fallback}}
                                            {{> "post-card" lazyLoad=true}}
                                        {{/foreach}}
                                    </div>
                                </div>
                            </section>
                        {{/if}}
                    {{/get}}
                {{/if}}
            {{/get}}
        {{else}}
            {{#get "posts" include="authors,tags" filter="visibility:public+id:-{{post.id}}+tags:[{{post.tags}}]" limit="4" as |public|}}
                {{#get "posts" include="authors,tags" filter="visibility:paid+id:-../post.id" limit="1" as |paid|}}
                    {{#if paid}}
                        <section class="gh-container is-grid gh-outer">
                            <div class="gh-container-inner gh-inner">
                                <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                <div class="gh-feed">
                                    {{#foreach paid}}
                                        {{> "post-card" lazyLoad=true}}
                                    {{/foreach}}

                                    {{#foreach public limit="3"}}
                                        {{> "post-card" lazyLoad=true}}
                                    {{/foreach}}
                                </div>
                            </div>
                        </section>
                    {{else}}
                        {{#if public}}
                            <section class="gh-container is-grid gh-outer">
                                <div class="gh-container-inner gh-inner">
                                    <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                    <div class="gh-feed">
                                        {{#foreach public}}
                                            {{> "post-card" lazyLoad=true}}
                                        {{/foreach}}
                                    </div>
                                </div>
                            </section>
                        {{else}}
                            {{#get "posts" include="authors,tags" filter="visibility:public+id:-{{../post.id}}" limit="4" as |fallback|}}
                                {{#if fallback}}
                                    <section class="gh-container is-grid gh-outer">
                                        <div class="gh-container-inner gh-inner">
                                            <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                            <div class="gh-feed">
                                                {{#foreach fallback}}
                                                    {{> "post-card" lazyLoad=true}}
                                                {{/foreach}}
                                            </div>
                                        </div>
                                    </section>
                                {{/if}}
                            {{/get}}
                        {{/if}}
                    {{/if}}
                {{/get}}
            {{/get}}
        {{/if}}
    {{else}}
        {{#if @member.paid}}
            {{#get "posts" include="authors,tags" filter="id:-{{post.id}}" limit="4" as |next|}}
                {{#if next}}
                    <section class="gh-container is-grid gh-outer">
                        <div class="gh-container-inner gh-inner">
                            <h2 class="gh-container-title">{{t "Read more"}}</h2>
                            <div class="gh-feed">
                                {{#foreach next}}
                                    {{> "post-card" lazyLoad=true}}
                                {{/foreach}}
                            </div>
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        {{else}}
            {{#get "posts" include="authors,tags" filter="visibility:public+id:-{{post.id}}" limit="4" as |public|}}
                {{#get "posts" include="authors,tags" filter="visibility:paid+id:-../post.id" limit="1" as |paid|}}
                    {{#if paid}}
                        <section class="gh-container is-grid gh-outer">
                            <div class="gh-container-inner gh-inner">
                                <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                <div class="gh-feed">
                                    {{#foreach paid}}
                                        {{> "post-card" lazyLoad=true}}
                                    {{/foreach}}

                                    {{#foreach public limit="3"}}
                                        {{> "post-card" lazyLoad=true}}
                                    {{/foreach}}
                                </div>
                            </div>
                        </section>
                    {{else}}
                        {{#if public}}
                            <section class="gh-container is-grid gh-outer">
                                <div class="gh-container-inner gh-inner">
                                    <h2 class="gh-container-title">{{t "Read more"}}</h2>
                                    <div class="gh-feed">
                                        {{#foreach public}}
                                            {{> "post-card" lazyLoad=true}}
                                        {{/foreach}}
                                    </div>
                                </div>
                            </section>
                        {{/if}}
                    {{/if}}
                {{/get}}
            {{/get}}
        {{/if}}
    {{/if}}
{{/if}}
