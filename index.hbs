{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

<main id="gh-main" class="gh-main buba-archive-main">
    <section class="buba-archive-hero gh-outer" aria-labelledby="buba-index-title">
        <div class="buba-archive-hero-inner gh-inner">
            <div>
                <p class="buba-kicker">Lernbibliothek</p>
                <h1 id="buba-index-title">Alle Beiträge für deinen Deutsch-Alltag.</h1>
                <p>Grammatik, Wortschatz, Beruf und Alltag an einem Ort. Wähle ein Thema oder lies die neuesten Lektionen der Reihe nach.</p>
            </div>
            <nav class="buba-archive-pills" aria-label="Themen">
                <a href="/tag/grammatik/">Grammatik</a>
                <a href="/tag/wortschatz/">Wortschatz</a>
                <a href="/tag/alltag/">Alltag</a>
                <a href="/tag/beruf/">Beruf</a>
                <a href="/tag/lernen/">Lernen</a>
            </nav>
        </div>
    </section>

    {{> "components/post-list" feed="index" postFeedStyle=@custom.post_feed_style showTitle=false showSidebar=false}}
    {{> "components/cta"}}
</main>
