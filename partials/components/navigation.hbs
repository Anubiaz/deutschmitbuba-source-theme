<header id="gh-navigation" class="gh-navigation is-{{#match navigationLayout "Logo on the left"}}left-logo{{else match navigationLayout "Stacked"}}stacked{{else}}middle-logo{{/match}}{{#match @custom.header_and_footer_color "Accent color"}} has-accent-color{{/match}} gh-outer">
    <div class="gh-navigation-inner gh-inner">

        <div class="gh-navigation-brand">
            <a class="gh-navigation-logo is-title" href="{{@site.url}}">
                {{#if @site.logo}}
                    <img src="{{img_url @site.logo size="xs"}}" alt="{{@site.title}}" width="96" height="96" loading="eager" decoding="async">
                {{else}}
                    <img src="{{asset "logo/buba_logo-96.webp"}}" alt="{{@site.title}}" width="96" height="96" loading="eager" decoding="async">
                {{/if}}
                <span class="buba-navigation-text">
                    <strong>{{@site.title}}</strong>
                    <small>Einfach verstehen. Sicher sprechen.</small>
                </span>
            </a>
            {{> "search-toggle"}}
            <button class="gh-burger gh-icon-button" aria-label="{{t "Menu"}}" aria-controls="gh-navigation-menu" aria-expanded="false">
                {{> "icons/burger"}}
                {{> "icons/close"}}
            </button>
        </div>

        <nav id="gh-navigation-menu" class="gh-navigation-menu">
            <ul class="buba-nav" role="list">
                <li{{#is "home"}} class="nav-current"{{/is}}><a href="{{@site.url}}"{{#is "home"}} aria-current="page"{{/is}}>Startseite</a></li>
                <li class="buba-nav-dropdown">
                    <a class="buba-nav-trigger" href="/tag/grammatik/" aria-haspopup="true" aria-controls="buba-topics-menu" aria-expanded="false">
                        Lernen <span class="buba-nav-chevron" aria-hidden="true"></span>
                    </a>
                    <ul id="buba-topics-menu" class="buba-nav-panel" role="list" aria-label="Lernen">
                        <li><a href="/tag/grammatik/"><strong>Grammatik</strong><small>Regeln verstehen</small></a></li>
                        <li><a href="/tag/wortschatz/"><strong>Wortschatz</strong><small>Neue Wörter lernen</small></a></li>
                        <li><a href="/tag/alltag/"><strong>Alltag</strong><small>Deutsch im Leben</small></a></li>
                        <li><a href="/tag/beruf/"><strong>Beruf</strong><small>Sicher handeln</small></a></li>
                        <li><a href="/tag/lernen/"><strong>Lernen lernen</strong><small>Tipps & Motivation</small></a></li>
                        <li><a href="/tag/kultur/"><strong>Kultur</strong><small>Sprache einordnen</small></a></li>
                    </ul>
                </li>
                {{#if @member}}
                    <li><a href="{{@site.url}}/mitglieder/">Lernbereich</a></li>
                {{else}}
                    <li><a href="{{#is "home"}}#mitgliedschaft{{else}}{{@site.url}}/#mitgliedschaft{{/is}}">Mitgliedschaft</a></li>
                {{/if}}
                <li><a href="{{#is "home"}}#neueste-beitraege{{else}}{{@site.url}}/#neueste-beitraege{{/is}}">Blog</a></li>
                <li><a href="/about/">Über Buba</a></li>
            </ul>
        </nav>

        <div class="gh-navigation-actions">
            {{#unless @site.members_enabled}}
                {{^match navigationLayout "Stacked"}}
                    {{> "search-toggle"}}
                {{/match}}
            {{else}}
                {{> "search-toggle"}}
                <div class="gh-navigation-members">
                    {{#unless @member}}
                        {{#unless @site.members_invite_only}}
                            <button type="button" class="buba-nav-portal-link" data-portal="signin">Anmelden</button>
                            {{#unless hideSubscribeButton}}
                                <button type="button" class="gh-button" data-portal="signup">Mitglied werden</button>
                            {{/unless}}
                        {{else}}
                            <button type="button" class="gh-button" data-portal="signin">Anmelden</button>
                        {{/unless}}
                    {{else}}
                        <a href="{{@site.url}}/mitglieder/">Lernbereich</a>
                        {{#if @member.paid}}
                            <button type="button" class="gh-button" data-portal="account">Konto</button>
                        {{else}}
                            {{#if @site.paid_members_enabled}}
                                <button type="button" class="gh-button" data-portal="upgrade">Premium</button>
                            {{else}}
                                <button type="button" class="gh-button" data-portal="account">Konto</button>
                            {{/if}}
                        {{/if}}
                    {{/unless}}
                </div>
            {{/unless}}
        </div>

    </div>
</header>
