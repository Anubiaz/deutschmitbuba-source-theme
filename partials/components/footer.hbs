<footer class="gh-footer{{#match @custom.header_and_footer_color "Accent color"}} has-accent-color{{/match}} gh-outer">
    <div class="gh-footer-inner gh-inner">

        {{#is "home"}}
            <div class="buba-footer-layout">
                <section class="buba-footer-brand" aria-label="{{@site.title}}">
                    <span class="buba-footer-logo">
                        <img src="{{asset "logo/buba_logo-96.webp"}}" alt="{{@site.title}}" width="96" height="96">
                        <span>
                            <strong>{{@site.title}}</strong>
                            {{#if @site.description}}<small>{{@site.description}}</small>{{/if}}
                        </span>
                    </span>
                    <p>Deutsch lernen mit Herz und Verstand.<br>Разом ми зможемо! 💙💛</p>
                    <div class="buba-footer-social" aria-label="Social Media">
                        <span aria-hidden="true"><img src="{{asset "icons/buba-social-instagram.svg"}}" alt="" loading="eager"></span>
                        <span aria-hidden="true"><img src="{{asset "icons/buba-social-youtube.svg"}}" alt="" loading="eager"></span>
                        <span aria-hidden="true"><img src="{{asset "icons/buba-social-tiktok.svg"}}" alt="" loading="eager"></span>
                        <span aria-hidden="true"><img src="{{asset "icons/buba-social-telegram.svg"}}" alt="" loading="eager"></span>
                    </div>
                </section>

                <nav class="buba-footer-column" aria-label="Lernen">
                    <h2>Lernen</h2>
                    <a href="/tag/grammatik/">Grammatik</a>
                    <a href="/tag/wortschatz/">Wortschatz</a>
                    <a href="/tag/alltag/">Alltag in Deutschland</a>
                    <a href="/tag/beruf/">Beruf & E-Mails</a>
                    <a href="/tag/pruefung/">Prüfung</a>
                </nav>

                <nav class="buba-footer-column" aria-label="Mitgliedschaft">
                    <h2>Mitgliedschaft</h2>
                    <a href="#mitgliedschaft">Vorteile</a>
                    <a href="#mitgliedschaft">Preise</a>
                    <a href="#/portal/signup" data-portal="signup">Mitglied werden</a>
                    <a href="#mitgliedschaft">Häufige Fragen</a>
                </nav>

                <nav class="buba-footer-column" aria-label="Über Buba">
                    <h2>Über Buba</h2>
                    <a href="/ueber-buba/">Über mich</a>
                    <a href="/ueber-buba/">Meine Mission</a>
                    <a href="/ueber-buba/">Empfehlungen</a>
                    <a href="/ueber-buba/">Kooperationen</a>
                </nav>

                <nav class="buba-footer-column" aria-label="Rechtliches">
                    <h2>Rechtliches</h2>
                    <a href="/impressum/">Impressum</a>
                    <a href="/datenschutz/">Datenschutz</a>
                    <a href="/agb/">AGB</a>
                    <a href="/widerruf/">Widerruf</a>
                </nav>

            </div>

            <p class="buba-footer-bottom">© {{date format="YYYY"}} {{@site.title}}. Alle Rechte vorbehalten.</p>
        {{else}}
            <div class="gh-footer-bar">
                <span class="gh-footer-logo is-title">
                    {{#if @site.logo}}
                        <img src="{{@site.logo}}" alt="{{@site.title}}">
                    {{else}}
                        {{@site.title}}
                    {{/if}}
                </span>
                <nav class="gh-footer-menu">
                    {{navigation type="secondary"}}
                </nav>
                <div class="gh-footer-copyright">
                    {{{t "Powered by {ghostlink}" ghostlink="<a href=\"https://ghost.org/\" target=\"_blank\" rel=\"noopener\">Ghost</a>"}}}
                </div>
            </div>

            {{#if @site.members_enabled}}
                {{#unless @member}}
                    <section class="gh-footer-signup">
                        <h2 class="gh-footer-signup-header is-title">
                            {{#if @custom.signup_heading}}{{@custom.signup_heading}}{{else}}{{@site.title}}{{/if}}
                        </h2>
                        <p class="gh-footer-signup-subhead is-body">
                            {{#if @custom.signup_subheading}}{{@custom.signup_subheading}}{{else}}{{@site.description}}{{/if}}
                        </p>
                        {{> "email-subscription" email_field_id="footer-email"}}
                    </section>
                {{/unless}}
            {{/if}}
        {{/is}}

    </div>
</footer>
